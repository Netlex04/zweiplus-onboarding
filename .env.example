# Docker Compose variables for the full stack (copy to .env to override).
# These are the single source of compose defaults — demo values only, no real
# secrets. All names match docker-compose.yml.

# --- Postgres ---
POSTGRES_USER=zweiplus
POSTGRES_PASSWORD=zweiplus
POSTGRES_DB=zweiplus

# --- Backend ---
# AI: deterministic offline stub by default (no key/server needed).
# Set AI_USE_STUB=0 and fill AI_BASE_URL/AI_API_KEY/AI_MODEL to use a live,
# OpenAI-compatible provider (OpenAI, or local Ollama/LM Studio/vLLM).
AI_USE_STUB=1
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=not-needed
AI_MODEL=gpt-4o-mini

SEED_ON_STARTUP=1
JWT_SECRET=dev-insecure-change-me
# JSON array (pydantic-settings parses list fields as JSON). Add more origins
# comma-separated inside the brackets, e.g. ["http://localhost:5173","https://app.example"].
CORS_ORIGINS=["http://localhost:5173"]
MAX_UPLOAD_MB=10

# --- Frontend (build-time) ---
# Backend URL baked into the bundle at build time.
VITE_API_URL=http://localhost:8000
