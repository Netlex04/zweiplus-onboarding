# Zweiplus Onboarding backend configuration (Architektur §9).
# Copy to backend/.env and adjust. Never commit real secrets.

# --- Database ---
# Runtime (PostgreSQL):
#   DATABASE_URL=postgresql+psycopg2://zweiplus:zweiplus@localhost:5432/zweiplus
# Local/test default (SQLite):
DATABASE_URL=sqlite:///./zweiplus.db

# --- AI provider (Seam, Annahme A7) ---
# LangChain ChatOpenAI against any OpenAI-compatible chat-completions API.
# Works with OpenAI (https://api.openai.com/v1) and local models via
# Ollama / LM Studio / vLLM (e.g. http://localhost:11434/v1).
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=not-needed            # any non-empty value for keyless local endpoints
AI_MODEL=gpt-4o-mini             # or a local model name, e.g. llama3.1
# Force the deterministic offline stub LLM (no key/server) — local smoke tests.
AI_USE_STUB=0

# --- File storage (Annahme A12) + upload limit (Annahme A6) ---
STORAGE_DIR=./storage
MAX_UPLOAD_MB=10

# --- Auth (used from Phase 2) ---
JWT_SECRET=dev-insecure-change-me

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173

# --- Seeds ---
# Set to 0 to skip automatic seed loading on app startup.
SEED_ON_STARTUP=1
