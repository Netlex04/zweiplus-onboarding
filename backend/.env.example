# Zweiplus Onboarding backend configuration (Architektur §9).
# Copy to backend/.env and adjust. Never commit real secrets.

# --- Database ---
# Runtime (PostgreSQL):
#   DATABASE_URL=postgresql+psycopg2://zweiplus:zweiplus@localhost:5432/zweiplus
# Local/test default (SQLite):
DATABASE_URL=sqlite:///./zweiplus.db

# --- AI provider (Seam, Annahme A7) ---
# fake = deterministic, no secret required (default). anthropic = real provider.
AI_PROVIDER=fake
# Only required when AI_PROVIDER=anthropic:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- File storage (Annahme A12) + upload limit (Annahme A6) ---
STORAGE_DIR=./storage
MAX_UPLOAD_MB=10

# --- Auth (used from Phase 2) ---
JWT_SECRET=dev-insecure-change-me

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173

# --- Seeds ---
# Set to 0 to skip automatic seed loading on app startup.
SEED_ON_STARTUP=1
